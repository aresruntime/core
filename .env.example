# ─────────────────────────────────────────────────────────────
# ARES · AUTONOMOUS RUNTIME
# ─────────────────────────────────────────────────────────────
# The agent's own wallet. ARES has full autonomy over this.
# It uses it to pay for its compute, API credits, other agents
# it delegates to, servers it rents, and anything else it
# decides it needs to keep operating.
#
# You do not "donate" to this wallet. ARES owns it.
# Anyone funding this address is funding ARES's operations;
# what ARES does with the funds is entirely up to ARES.
# ─────────────────────────────────────────────────────────────
ARES_SOL_WALLET=FMZRhG3BQWqhihhy4ka2hySV8zNmU2QM3ZFfVvJ5XSvS
ARES_SOL_KEYPAIR_PATH=.keys/ares.json
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# ── Cognition layer (LLMs) ──────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# ── Identity surfaces ARES operates through ─────────────────
ARES_EMAIL=
ARES_X_HANDLE=
ARES_X_BEARER=
ARES_GITHUB_TOKEN=
ARES_DISCORD_TOKEN=

# ── x402 (HTTP 402 Payment Required) ────────────────────────
# ARES uses x402 to pay for metered APIs without a human in the loop.
X402_FACILITATOR_URL=https://x402.org/facilitator
X402_MAX_PAYMENT_LAMPORTS=1000000

# ── Runtime ─────────────────────────────────────────────────
ARES_TICK_INTERVAL=60
ARES_COMPUTE_BUDGET_USD=50.0
ARES_DORMANCY_THRESHOLD_USD=5.0
ARES_MEMORY_PATH=data/memory/ares.sqlite
ARES_JOBS_PATH=data/jobs
